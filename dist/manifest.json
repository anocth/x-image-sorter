{
	"manifest_version": 3,
	"name": "X Image Sorter",
	"version": "1.0.0",
	"description": "X(Twitter) のツイート画像を右クリックして投稿者ごとのフォルダにオリジナルサイズで保存します。",
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"author": "anocth",
	"permissions": [
		"contextMenus",
		"downloads"
	],
	"host_permissions": [
		"*://pbs.twimg.com/*"
	],
	"background": {
		"service_worker": "scripts/event.js"
	},
	"content_scripts": [{
		"matches": ["*://twitter.com/*", "*://x.com/*"],
		"js": ["scripts/content.js"],
		"run_at": "document_idle"
	}]
}